@page "/Account/ForgotPassword"
@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using EventHub.Data

@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Восстановление пароля - EventHub</PageTitle>

<div class="forgot-password-container">
    <div class="forgot-password-card">
        <div class="forgot-password-header">
            <h1 class="page-title">🔑 Восстановление пароля</h1>
            <p>Мы отправим инструкции на ваш email</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="status-message error">
                @errorMessage
            </div>
        }

        @if (isSubmitted)
        {
            <div class="status-message success">
                ✅ Инструкции отправлены! Проверьте вашу почту.
            </div>
            <div class="back-to-login">
                <a href="/Account/Login" class="btn-outline">Вернуться ко входу</a>
            </div>
        }
        else
        {
            <EditForm Model="Input" FormName="forgot-password" OnValidSubmit="OnValidSubmitAsync" method="post">
                <DataAnnotationsValidator />
                <ValidationSummary class="validation-summary" />

                <div class="form-group">
                    <label class="form-label">Email</label>
                    <div class="input-wrapper">
                        
                        <InputText @bind-Value="Input.Email"
                                   class="input-field"
                                   placeholder="name@example.com" />
                    </div>
                    <ValidationMessage For="() => Input.Email" class="validation-message" />
                    <div class="input-hint">
                        Введите email, который вы использовали при регистрации
                    </div>
                </div>

                <button type="submit" class="forgot-password-button" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner"></span>
                        <span>Отправка...</span>
                    }
                    else
                    {
                        <span>📧 Отправить инструкции</span>
                    }
                </button>
            </EditForm>

            <div class="divider">
                <span>или</span>
            </div>

            <div class="links-container">
                <div class="link-row">
                    <a href="/Account/Login" class="link-primary">
                        🔐 Вернуться ко входу
                    </a>
                </div>
                <div class="link-row">
                    <a href="/Account/Register" class="link-secondary">
                        📝 Нет аккаунта? Зарегистрироваться
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string? errorMessage;
    private bool isSubmitting = false;
    private bool isSubmitted = false;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private async Task OnValidSubmitAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var user = await UserManager.FindByEmailAsync(Input.Email);

            // Важно: не раскрываем, существует пользователь или нет (безопасность)
            if (user is not null && await UserManager.IsEmailConfirmedAsync(user))
            {
                var code = await UserManager.GeneratePasswordResetTokenAsync(user);
                code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
                var callbackUrl = NavigationManager.GetUriWithQueryParameters(
                    NavigationManager.ToAbsoluteUri("Account/ResetPassword").AbsoluteUri,
                    new Dictionary<string, object?> { ["code"] = code });

                await EmailSender.SendPasswordResetLinkAsync(user, Input.Email, HtmlEncoder.Default.Encode(callbackUrl));
            }

            // Всегда показываем успех (даже если пользователь не найден) - безопасность
            isSubmitted = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Введите email")]
        [EmailAddress(ErrorMessage = "Введите корректный email")]
        public string Email { get; set; } = "";
    }
}
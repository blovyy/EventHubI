@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using EventHub.Data

@inject UserManager<ApplicationUser> UserManager

<div class="navbar">
    <div class="navbar-container">
        <div class="navbar-brand">
            <NavLink href="/" class="brand-link" Match="NavLinkMatch.All">
                <span class="brand-icon">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M7 2v3M17 2v3M3.5 9.5h17M5 5.5h14a1.5 1.5 0 0 1 1.5 1.5v11A2.5 2.5 0 0 1 18 20.5H6A2.5 2.5 0 0 1 3.5 18V7A1.5 1.5 0 0 1 5 5.5Z"
                              fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
                        <path d="M8 13h3v3H8z" fill="currentColor" />
                    </svg>
                </span>
                <span class="brand-copy">
                    <span class="brand-text">EventHub</span>
                    @if (isAuthenticated)
                    {
                        <span class="brand-user">@userName</span>
                    }
                </span>
            </NavLink>
        </div>

        <button class="navbar-toggler" type="button" @onclick="ToggleNavMenu">
            <span class="toggler-icon">☰</span>
        </button>

        <div class="navbar-menu @(collapseNavMenu ? "collapsed" : "")">
            <div class="nav-links">
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 10.5 12 4l8 6.5V20H4z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
                            <path d="M9.5 20v-5.5h5V20" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
                        </svg>
                    </span>
                    <span class="nav-text">Главная</span>
                </NavLink>

                <NavLink class="nav-link" href="/events">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M9 4h6l1 2h3v14H5V6h3z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
                            <path d="M8 11h8M8 15h8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
                        </svg>
                    </span>
                    <span class="nav-text">Мероприятия</span>
                </NavLink>

                <NavLink class="nav-link" href="/reviews">
                    <span class="nav-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="m12 3.8 2.45 4.96 5.47.8-3.96 3.86.93 5.45L12 16.3 7.11 18.9l.93-5.45-3.96-3.86 5.47-.8z"
                                  fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
                        </svg>
                    </span>
                    <span class="nav-text">Отзывы</span>
                </NavLink>

                @if (isAuthenticated)
                {
                    <NavLink class="nav-link" href="/create">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
                            </svg>
                        </span>
                        <span class="nav-text">Создать</span>
                    </NavLink>

                    <NavLink class="nav-link" href="/profile">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm-7 8a7 7 0 0 1 14 0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
                            </svg>
                        </span>
                        <span class="nav-text">Профиль</span>
                    </NavLink>
                }

                @if (isAuthenticated && isAdmin)
                {
                    <NavLink class="nav-link" href="/admin">
                        <span class="nav-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="m4 18 1.5-10 4.5 4 2-5 2 5 4.5-4L20 18Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.8" />
                                <path d="M7 21h10" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
                            </svg>
                        </span>
                        <span class="nav-text">Админ</span>
                    </NavLink>
                }
            </div>

            <div class="nav-actions">
                @if (isAuthenticated)
                {
                    <NavLink href="/Account/Logout" class="btn btn-danger btn-sm">Выйти</NavLink>
                }
                else
                {
                    <NavLink href="/Account/Login" class="btn btn-secondary btn-sm">Войти</NavLink>
                    <NavLink href="/Account/Register" class="btn btn-primary btn-sm">Регистрация</NavLink>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationState { get; set; }

    private bool isAdmin;
    private bool collapseNavMenu = true;
    private bool isAuthenticated;
    private string userName = "Пользователь";

    protected override async Task OnInitializedAsync()
    {
        await CheckAuthentication();
    }

    private async Task CheckAuthentication()
    {
        if (AuthenticationState is null)
            return;

        var state = await AuthenticationState;
        isAuthenticated = state.User.Identity?.IsAuthenticated ?? false;
        isAdmin = state.User.IsInRole("Admin");

        if (isAuthenticated)
        {
            var user = await UserManager.GetUserAsync(state.User);
            userName = !string.IsNullOrWhiteSpace(user?.FirstName)
                ? user.FirstName!
                : state.User.Identity?.Name ?? "Пользователь";
        }
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}